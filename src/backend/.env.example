# PsyFlow backend environment template
# Copy to .env.local and adjust values for your account/stage.

# Runtime stage
STAGE=dev

# DynamoDB table names
PATIENTS_TABLE_NAME=psyflow-patients-dev
SESSIONS_TABLE_NAME=psyflow-patient-sessions-dev
MOOD_TABLE_NAME=psyflow-patient-mood-dev
TASKS_TABLE_NAME=psyflow-patient-tasks-dev
CHAT_TABLE_NAME=psyflow-patient-chat-dev
EXERCISES_TABLE_NAME=psyflow-exercises-dev
ORGANIZATIONS_TABLE_NAME=psyflow-organizations-dev
AGENDA_EVENTS_TABLE_NAME=psyflow-agenda-events-dev
AGENDA_RECURRENCE_RULES_TABLE_NAME=psyflow-agenda-recurrence-rules-dev

# Optional, required for upload/transcription features
TRANSCRIPTIONS_BUCKET_NAME=
AUDIO_UPLOADS_BUCKET_NAME=

# KMS key ARN for clinical session content encryption (envelope encryption).
# Required — the server will refuse to start without this.
# Set to the ClinicalDataKey ARN output from the CDK stack.
PSYFLOW_KMS_KEY_ARN=

# AWS SDK config (used by boto3)
# Set AWS_PROFILE only if you use a named profile, e.g. AWS_PROFILE=default
# AWS_PROFILE=default
AWS_REGION=us-east-1
USER_POOL_ID=USER_POOL_ID_PLACEHOLDER

# Comma-separated list of allowed browser origins for CORS
CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional local testing delay (seconds) applied to each non-OPTIONS request
API_DELAY_SECONDS=0
